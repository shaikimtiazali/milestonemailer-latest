<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Work Anniversary — {{name}}</title>
    <style>
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
      }
      body {
        margin: 0 !important;
        padding: 0 !important;
        background-color: #f0f0f0;
      }

      @media only screen and (max-width: 600px) {
        .container {
          width: 100% !important;
          max-width: 100% !important;
        }
        .header-pad {
          padding: 32px 24px 28px !important;
        }
        .inner-pad {
          padding: 28px 24px 20px !important;
        }
        .signoff-pad {
          padding: 0 24px 28px !important;
        }
        .footer-pad {
          padding: 14px 24px !important;
        }
        .badge {
          width: 64px !important;
          height: 64px !important;
          line-height: 64px !important;
        }
        .badge-num {
          font-size: 20px !important;
        }
        .heading-size {
          font-size: 19px !important;
        }
        .body-size {
          font-size: 14px !important;
        }
        .title-size {
          font-size: 22px !important;
        }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background-color:#f0f0f0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding:32px 16px;">

          <table
            class="container"
            width="560"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="max-width:560px;width:100%;border-radius:12px;overflow:hidden;box-shadow:0 2px 20px rgba(0,0,0,0.12);"
          >

            <!-- DARK HEADER -->
            <tr>
              <td
                class="header-pad"
                align="center"
                style="background-color:#0F1F3D;padding:44px 40px 36px;"
              >
                <div
                  class="badge"
                  style="display:inline-block;background-color:#1E3A5F;border-radius:50%;width:80px;height:80px;line-height:80px;text-align:center;margin-bottom:16px;"
                >
                  <span
                    class="badge-num"
                    style="font-size:26px;font-weight:800;color:#F5C842;font-family:Arial,sans-serif;"
                  >
                    {{years}}
                  </span>
                </div>
                <p
                  style="margin:0 0 6px;font-size:11px;letter-spacing:3px;color:#8899AA;
                text-transform:uppercase;font-family:Arial,sans-serif;"
                >
                  {{yearLabel}}
                  of Excellence
                </p>
                <p
                  class="title-size"
                  style="margin:0;font-size:26px;font-weight:700;color:#ffffff;
                font-family:Arial,sans-serif;letter-spacing:-0.5px;"
                >
                  Work Anniversary
                </p>
                <div
                  style="width:40px;height:2px;background-color:#F5C842;margin:16px auto 0;"
                ></div>
              </td>
            </tr>

            <!-- BODY -->
            <tr>
              <td
                class="inner-pad"
                style="background-color:#ffffff;padding:36px 40px 24px;"
              >
                <p
                  class="heading-size"
                  style="margin:0 0 14px;font-size:22px;font-weight:700;color:#1a1a1a;
                font-family:Arial,sans-serif;"
                >
                  Congratulations,
                  {{name}}!
                </p>
                <p
                  class="body-size"
                  style="margin:0 0 18px;font-size:15px;color:#444444;line-height:1.75;
                font-family:Arial,sans-serif;"
                >
                  Today marks
                  <strong>{{years}} {{yearLabel}}</strong>
                  since you joined the
                  <strong>{{company}}</strong>
                  family. Your dedication, growth, and contributions have made a
                  lasting impact — and we don't take that for granted.
                </p>
                <p
                  class="body-size"
                  style="margin:0;font-size:15px;color:#444444;line-height:1.75;
                font-family:Arial,sans-serif;"
                >
                  Here's to many more milestones ahead. Thank you for being the
                  backbone of what we do. 🏆
                </p>
              </td>
            </tr>

            <!-- DIVIDER -->
            <tr>
              <td style="background-color:#ffffff;padding:0 40px;">
                <div style="height:1px;background-color:#f0f0f0;"></div>
              </td>
            </tr>

            <!-- SIGN OFF -->
            <tr>
              <td
                class="signoff-pad"
                style="background-color:#ffffff;padding:20px 40px 36px;"
              >
                <p
                  style="margin:0;font-size:14px;color:#888888;font-family:Arial,sans-serif;
                line-height:1.6;"
                >
                  With gratitude,<br />
                  <strong style="color:#1a1a1a;">HR Team &middot;
                    {{company}}</strong>
                </p>
              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td
                class="footer-pad"
                align="center"
                style="background-color:#F7F8FA;padding:16px 40px;border-top:1px solid #EEEEEE;"
              >
                <p
                  style="margin:0;font-size:11px;color:#BBBBBB;font-family:Arial,sans-serif;"
                >
                  Automated work anniversary message &middot;
                  {{company}}
                  HR
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>